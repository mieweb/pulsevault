{
  "name": "@mieweb/pulsevault",
  "version": "0.0.2",
  "description": "Fastify plugin for resumable video uploads via TUS, with a pluggable storage adapter and a filesystem-first local-storage default.",
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./augment": {
      "types": "./dist/augment.d.ts",
      "import": "./dist/augment.js",
      "default": "./dist/augment.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs"
  },
  "keywords": [
    "fastify",
    "fastify-plugin",
    "tus",
    "tus-server",
    "video",
    "upload",
    "resumable",
    "pulsevault"
  ],
  "author": "Medical Informatics Engineering, Inc.",
  "contributors": [
    "morepriyam (https://github.com/morepriyam)"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mieweb/pulsevault.git"
  },
  "bugs": {
    "url": "https://github.com/mieweb/pulsevault/issues"
  },
  "homepage": "https://github.com/mieweb/pulsevault#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "fastify": "^5.8.5"
  },
  "dependencies": {
    "@fastify/send": "^4.1.0",
    "@tus/file-store": "^2.0.0",
    "@tus/server": "^2.0.0",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fastify": "^5.8.5",
    "typescript": "^6.0.2"
  }
}
