{
  "name": "@mieweb/pulsevault",
  "version": "0.1.0",
  "description": "Resumable video uploads via TUS for Fastify (plugin) or any Node backend (framework-agnostic core), with a pluggable storage adapter and a filesystem-first local-storage default.",
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./augment": {
      "types": "./dist/augment.d.ts",
      "import": "./dist/augment.js",
      "default": "./dist/augment.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist",
    "core.js",
    "core.d.ts",
    "augment.js",
    "augment.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "PROTOCOL.md",
    "OPERATIONS.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "e2e": "npm run build && node scripts/e2e-tus.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "fastify",
    "fastify-plugin",
    "express",
    "meteor",
    "tus",
    "tus-server",
    "video",
    "upload",
    "resumable",
    "pulsevault"
  ],
  "author": "Medical Informatics Engineering, Inc.",
  "contributors": [
    "morepriyam (https://github.com/morepriyam)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mieweb/pulsevault.git"
  },
  "bugs": {
    "url": "https://github.com/mieweb/pulsevault/issues"
  },
  "homepage": "https://github.com/mieweb/pulsevault#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "peerDependencies": {
    "fastify": "^5.8.5"
  },
  "dependencies": {
    "@fastify/send": "^4.1.0",
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.1",
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.1"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1074.0",
    "@aws-sdk/s3-request-presigner": "^3.1074.0",
    "@tus/s3-store": "^2.0.4"
  }
}
