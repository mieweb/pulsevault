# PulseVault Meteor demo server — environment variables.
#
# Copy to `.env` and fill in. Meteor doesn't read `.env` automatically — load
# it with something like `node --env-file=.env $(which meteor) run`, or just
# export the variables in your shell before running `meteor run`.
# `.env` is gitignored; never commit secrets.

# Where uploads are stored on disk. Meteor bundles run from a generated build
# directory, not this source tree, so this must be an absolute path if you want
# uploads to persist across restarts — otherwise defaults to a tmpdir that's
# wiped on reboot.
PULSEVAULT_DIR=

# Deployment-wide default upload unit advertised via GET /pulsevault/capabilities.
# "merged" (default) uploads one video + captions + thumbnail per session;
# "segment" uploads each clip separately with an ordering manifest. Purely
# advisory — a single pairing link can override it with ?uploadUnit=... .
UPLOAD_UNIT=merged
