# PulseVault minimal Fastify demo — environment variables.
#
# Copy to `.env` and load it when starting the server, e.g.:
#   node --env-file=.env server.mjs
# (Node 20.6+ supports --env-file.) `.env` is gitignored; never commit secrets.

# ---------------------------------------------------------------------------
# Demo server
# ---------------------------------------------------------------------------
# Port / host the demo listens on.
PORT=3000
HOST=0.0.0.0

# Deployment-wide upload-unit default advertised via
# GET /pulsevault/capabilities: "beat" or "merged" (README "Upload unit").
UPLOAD_UNIT=beat
